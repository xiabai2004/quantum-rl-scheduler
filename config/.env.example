# 天衍云平台 API 配置
# 警告：请勿将真实凭证提交到版本控制系统！

# ──────────────────────────────────────────────────────────────
# 天衍云 API 凭证（真实模式必需，Mock 模式可留空）
# ──────────────────────────────────────────────────────────────
# API 主密钥：从天衍云个人中心获取，真实模式必需
TIANYAN_API_KEY=your_api_key_here
# API 密钥别名（与 TIANYAN_API_KEY 等效，设置其一即可）
TIANYAN_API_TOKEN=your_api_token_here
# API Secret（可选，仅当平台要求双因子认证时填写）
TIANYAN_API_SECRET=your_api_secret_here
# 应用 ID（可选，仅当使用应用级鉴权时填写）
TIANYAN_APP_ID=your_app_id_here
# API 基础 URL
TIANYAN_BASE_URL=https://api.tianyanyun.cn/v1
# 默认量子计算机名称
TIANYAN_MACHINE=tianyan_s

# ──────────────────────────────────────────────────────────────
# 数据库配置
# ──────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/scheduler.db

# ──────────────────────────────────────────────────────────────
# Redis 缓存配置
# ──────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ──────────────────────────────────────────────────────────────
# 日志配置
# ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ──────────────────────────────────────────────────────────────
# Web 界面配置
# ──────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_DEBUG=true

# ──────────────────────────────────────────────────────────────
# 仿真模式配置（开发阶段设为 true）
# ──────────────────────────────────────────────────────────────
SIMULATION_MODE=true

# ──────────────────────────────────────────────────────────────
# 量子退火配置
# ──────────────────────────────────────────────────────────────
ANNEALING_ENABLED=true
ANNEALING_SIMULATION=true
